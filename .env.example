# Copy this file to .env. Never commit the real value.
# The default live evidence-summary provider. The deterministic safety gate works
# without any model credential.
MODEL_PROVIDER=nova
AWS_BEARER_TOKEN_BEDROCK=
AWS_REGION=us-east-1
NOVA_MODEL_ID=amazon.nova-pro-v1:0

# Set a long random value for a production-like HMAC-sealed audit chain.
# Without it, MittiGuard uses a visibly labelled development-only SHA-256 chain
# and intentionally refuses to record a human review attestation.
MITTIGUARD_AUDIT_SECRET=

# Local development uses data/store.json when this is empty. Containers use a
# separate mounted runtime directory; see docs/DEPLOY.md.
MITTIGUARD_STORE_PATH=

# The public hackathon instance is an explicitly synthetic jury demo. Set this
# to operations and configure MITTIGUARD_OPERATOR_KEY before handling real data.
MITTIGUARD_MODE=jury-demo
MITTIGUARD_OPERATOR_KEY=

# Set the canonical HTTPS origin on a deployed instance. Field Capture links
# use this instead of request headers, so a proxy/client cannot choose where a
# one-time capability points.
MITTIGUARD_PUBLIC_BASE_URL=

# Optional alternative provider. Only set this if you have OpenAI API billing.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.6
PORT=3000
